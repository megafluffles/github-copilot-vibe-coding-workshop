FROM ubuntu:24.04

# Set DEBIAN_FRONTEND for the entire build process (or specific RUN commands)
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    gnupg \
    ca-certificates \
    software-properties-common \
    build-essential \
    unzip \
    apt-transport-https \
    lsb-release \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Python 3.12.3
RUN add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get install -y python3.12 python3.12-venv python3.12-dev && \
    rm -rf /var/lib/apt/lists/*
RUN ln -sf /usr/bin/python3.12 /usr/bin/python3

# Install Node.js v22.17.0 and npm 10.9.2
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    npm install -g npm@10.9.2 && \
    rm -rf /var/lib/apt/lists/*

# Install OpenJDK 21.0.7 (LTS)
RUN wget https://download.oracle.com/java/21/latest/jdk-21_linux-x64_bin.deb && \
    apt-get install -y ./jdk-21_linux-x64_bin.deb && \
    rm jdk-21_linux-x64_bin.deb

# Install .NET SDK 8.0.410
RUN wget https://dotnet.microsoft.com/download/dotnet/scripts/v1/dotnet-install.sh && \
    chmod +x dotnet-install.sh && \
    ./dotnet-install.sh --version 8.0.410 --install-dir /usr/share/dotnet && \
    ln -s /usr/share/dotnet/dotnet /usr/bin/dotnet && \
    rm dotnet-install.sh

# Set default shell
SHELL ["/bin/bash", "-c"]

CMD ["bash"]
